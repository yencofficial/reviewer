function parseContent(text) {
    const lines = text.split('\n').filter(l => l.trim());
    const title = lines[0] || 'Study Material';
    const sections = [];
    let currentSection = { heading: 'Overview', points: [] };
    const terms = [];
    const facts = [];

    lines.forEach((line, i) => {
        const trimmed = line.trim();
        if (i === 0) return;
        if ((trimmed.length < 60 && trimmed === trimmed.toUpperCase() && trimmed.length > 2) ||
            trimmed.endsWith(':') || trimmed.startsWith('#')) {
            if (currentSection.points.length > 0) sections.push(currentSection);
            currentSection = { heading: trimmed.replace(/^#+\s*/, '').replace(/:$/, ''), points: [] };
        } else if (trimmed.includes(' - ') || trimmed.includes(': ')) {
            const sep = trimmed.includes(' - ') ? ' - ' : ': ';
            const [term, def] = trimmed.split(sep);
            if (term && def) terms.push({ term: term.replace(/^[-•*]\s*/, ''), definition: def });
            currentSection.points.push(trimmed);
        } else if (trimmed.startsWith('-') || trimmed.startsWith('•') || trimmed.startsWith('*')) {
            currentSection.points.push(trimmed.replace(/^[-•*]\s*/, ''));
        } else {
            currentSection.points.push(trimmed);
            if (trimmed.length > 20) facts.push(trimmed);
        }
    });
    if (currentSection.points.length > 0) sections.push(currentSection);

    if (terms.length < 3) {
        facts.slice(0, 10).forEach(f => {
            const words = f.split(' ');
            if (words.length > 4) terms.push({ term: words.slice(0, 3).join(' ') + '...', definition: f });
        });
    }

    appState.parsed = { title, sections, terms, facts };
    appState.flashcards = terms.map(t => ({ front: t.term, back: t.definition, mastered: false }));
    appState.stats.topics = sections.length;
    generateQuiz();
    renderReviewer();
    renderFlashcards();
    updateDashboard();
}

function renderReviewer() {
    const container = document.getElementById('reviewer-content');
    if (!appState.parsed) return;
    const p = appState.parsed;
    let html = `<div class="glass rounded-2xl p-6"><h3 class="text-xl font-bold mb-3">${p.title}</h3>`;
    html += `<p class="text-sm opacity-60 mb-4">~${Math.ceil(appState.content.split(' ').length / 200)} min read • ${p.sections.length} sections • ${p.terms.length} key terms</p>`;
    p.sections.forEach(s => {
        html += `<div class="mb-4"><h4 class="font-semibold text-blue-600 dark:text-blue-400 mb-1">${s.heading}</h4><ul class="list-disc pl-5 space-y-1">`;
        s.points.forEach(pt => { html += `<li class="text-sm">${pt}</li>`; });
        html += `</ul></div>`;
    });
    if (p.terms.length > 0) {
        html += `<h4 class="font-semibold text-blue-600 dark:text-blue-400 mb-2 mt-4">Key Terms</h4><div class="grid gap-2">`;
        p.terms.forEach(t => { html += `<div class="p-2 rounded-lg bg-blue-50 dark:bg-slate-700 text-sm"><strong>${t.term}</strong>: ${t.definition}</div>`; });
        html += `</div>`;
    }
    html += `</div>`;
    container.innerHTML = html;
    document.querySelector('[data-template-id="reviewer-empty"]').classList.add('hidden');
}

document.getElementById('reviewer-search').addEventListener('input', (e) => {
    const q = e.target.value.toLowerCase();
    const items = document.querySelectorAll('#reviewer-content li, #reviewer-content .p-2');
    items.forEach(el => { el.style.display = !q || el.textContent.toLowerCase().includes(q) ? '' : 'none'; });
});

function renderFlashcards() {
    if (appState.flashcards.length === 0) return;
    document.querySelector('[data-template-id="flashcards-empty"]').classList.add('hidden');
    document.getElementById('flashcard-area').classList.remove('hidden');
    showCard();
}

function showCard() {
    const cards = appState.flashcards.filter(c => !c.mastered);
    if (cards.length === 0) {
        document.getElementById('fc-front').textContent = 'All cards mastered! 🎉';
        document.getElementById('fc-back').textContent = 'Great job!';
        return;
    }
    const idx = appState.fcIndex % cards.length;
    document.getElementById('fc-front').textContent = cards[idx].front;
    document.getElementById('fc-back').textContent = cards[idx].back;
    document.getElementById('fc-progress').textContent = `${idx + 1} / ${cards.length} (${appState.fcMastered.size} mastered)`;
    document.getElementById('flashcard').classList.remove('flipped');
}

document.getElementById('flashcard').addEventListener('click', () => { document.getElementById('flashcard').classList.toggle('flipped'); });
document.getElementById('fc-next').addEventListener('click', () => { appState.fcIndex++; showCard(); });
document.getElementById('fc-prev').addEventListener('click', () => { appState.fcIndex = Math.max(0, appState.fcIndex - 1); showCard(); });
document.getElementById('fc-shuffle').addEventListener('click', () => { appState.flashcards.sort(() => Math.random() - 0.5); appState.fcIndex = 0; showCard(); });
document.getElementById('fc-master').addEventListener('click', () => {
    const cards = appState.flashcards.filter(c => !c.mastered);
    const idx = appState.fcIndex % cards.length;
    if (cards[idx]) { cards[idx].mastered = true; appState.fcMastered.add(idx); }
    appState.stats.cardsMastered = appState.fcMastered.size;
    showCard();
    saveProgress();
});

function generateQuiz() {
    if (!appState.parsed) return;
    const questions = [];
    const p = appState.parsed;
    p.terms.slice(0, 5).forEach(t => {
        const wrong = p.terms.filter(x => x !== t).sort(() => Math.random() - 0.5).slice(0, 3).map(x => x.definition);
        const options = [...wrong, t.definition].sort(() => Math.random() - 0.5);
        questions.push({ type: 'mc', question: `What is: ${t.term}?`, options, answer: t.definition });
    });
    p.facts.slice(0, 3).forEach(f => {
        questions.push({ type: 'tf', question: f, answer: 'True', explanation: 'This statement is from your notes.' });
    });
    p.terms.slice(0, 3).forEach(t => {
        questions.push({ type: 'fib', question: `______: ${t.definition}`, answer: t.term });
    });
    appState.quizQuestions = questions.sort(() => Math.random() - 0.5);
    if (questions.length > 0) {
        document.querySelector('[data-template-id="quiz-empty"]').classList.add('hidden');
        document.getElementById('quiz-start').classList.remove('hidden');
    }
}

document.getElementById('quiz-start').addEventListener('click', () => {
    document.getElementById('quiz-start').classList.add('hidden');
    document.getElementById('quiz-results').classList.add('hidden');
    renderQuiz();
});

function renderQuiz() {
    const area = document.getElementById('quiz-area');
    area.classList.remove('hidden');
    area.innerHTML = '';
    appState.quizAnswers = {};
    appState.quizQuestions.forEach((q, i) => {
        let html = `<div class="glass rounded-xl p-4"><p class="font-semibold mb-2">${i + 1}. ${q.question}</p>`;
        if (q.type === 'mc') {
            q.options.forEach(opt => { html += `<label class="block p-2 rounded-lg hover:bg-blue-50 dark:hover:bg-slate-700 cursor-pointer transition"><input type="radio" name="q${i}" value="${opt}" class="mr-2">${opt}</label>`; });
        } else if (q.type === 'tf') {
            html += `<label class="block p-2 rounded-lg hover:bg-blue-50 dark:hover:bg-slate-700 cursor-pointer transition"><input type="radio" name="q${i}" value="True" class="mr-2">True</label>`;
            html += `<label class="block p-2 rounded-lg hover:bg-blue-50 dark:hover:bg-slate-700 cursor-pointer transition"><input type="radio" name="q${i}" value="False" class="mr-2">False</label>`;
        } else if (q.type === 'fib') {
            html += `<input type="text" name="q${i}" class="w-full p-2 rounded-lg border border-gray-300 dark:border-slate-600 dark:bg-slate-800" placeholder="Your answer...">`;
        }
        html += `</div>`;
        area.innerHTML += html;
    });
    document.getElementById('quiz-submit').classList.remove('hidden');
}

document.getElementById('quiz-submit').addEventListener('click', (e) => {
    e.preventDefault();
    let correct = 0;
    appState.quizQuestions.forEach((q, i) => {
        let userAnswer;
        if (q.type === 'fib') { const input = document.querySelector(`input[name="q${i}"]`); userAnswer = input ? input.value.trim() : ''; }
        else { const checked = document.querySelector(`input[name="q${i}"]:checked`); userAnswer = checked ? checked.value : ''; }
        if (userAnswer.toLowerCase() === q.answer.toLowerCase()) correct++;
    });
    const score = Math.round((correct / appState.quizQuestions.length) * 100);
    appState.stats.quizScore = score;
    document.getElementById('quiz-area').classList.add('hidden');
    document.getElementById('quiz-submit').classList.add('hidden');
    document.getElementById('quiz-results').classList.remove('hidden');
    document.getElementById('quiz-score').textContent = `${score}% (${correct}/${appState.quizQuestions.length})`;
    saveProgress();
});

document.getElementById('quiz-retry').addEventListener('click', () => {
    appState.quizQuestions.sort(() => Math.random() - 0.5);
    document.getElementById('quiz-results').classList.add('hidden');
    renderQuiz();
});

document.querySelectorAll('.diff-btn').forEach(btn => { btn.addEventListener('click', () => generatePractice(btn.dataset.diff)); });

function generatePractice(difficulty) {
    if (!appState.parsed) return;
    const area = document.getElementById('practice-area');
    area.classList.remove('hidden');
    area.innerHTML = '';
    const terms = [...appState.parsed.terms].sort(() => Math.random() - 0.5).slice(0, 5);
    terms.forEach((t, i) => {
        let html = `<div class="glass rounded-xl p-4"><p class="font-semibold mb-2">${i + 1}. `;
        if (difficulty === 'easy') html += `Define: ${t.term}</p><p class="text-sm opacity-70 mt-2 hidden answer">${t.definition}</p>`;
        else if (difficulty === 'hard') html += `Explain in detail: ${t.term}</p><p class="text-sm opacity-70 mt-2 hidden answer">${t.definition}</p>`;
        else html += `What is: ${t.term}?</p><p class="text-sm opacity-70 mt-2 hidden answer">${t.definition}</p>`;
        html += `<button class="reveal-btn mt-2 text-sm text-blue-600 hover:underline">Show Answer</button></div>`;
        area.innerHTML += html;
    });
    area.querySelectorAll('.reveal-btn').forEach(btn => { btn.addEventListener('click', () => { btn.previousElementSibling.classList.toggle('hidden'); }); });
}

function updateDashboard() {
    document.getElementById('stat-topics').textContent = appState.stats.topics;
    document.getElementById('stat-quiz').textContent = appState.stats.quizScore + '%';
    document.getElementById('stat-cards').textContent = appState.stats.cardsMastered;
    document.getElementById('stat-time').textContent = appState.stats.timeStudied + 'm';
